# Reverse-proxy vhost for CSAT — serves https://csat.icuracao.com from the local
# csat service on 127.0.0.1:8080. Drop in /etc/nginx/sites-available (or conf.d),
# enable, and obtain a cert. TLS lines below are filled in by `certbot --nginx`.

server {
    listen 80;
    listen [::]:80;
    server_name csat.icuracao.com;
    # certbot serves the ACME challenge here, then redirects to HTTPS.
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name csat.icuracao.com;

    ssl_certificate     /etc/letsencrypt/live/csat.icuracao.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/csat.icuracao.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host              $host;
        proxy_set_header X-Forwarded-For   $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
    }
}
