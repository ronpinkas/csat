{{define "title"}}{{.SiteName}} — Dashboard{{end}}
{{define "content"}}
<header class="admin-head">
  {{if .LogoURL}}<img class="logo" src="{{.LogoURL}}" alt="{{.SiteName}}">{{end}}
  <h1>{{.SiteName}}</h1>
  <nav class="admin-nav">
    <a href="/dashboard">Dashboard</a>
    {{if eq .User.Role "admin"}}<a href="/survey">Survey</a><a href="/links">Invitations</a><a href="/users">Users</a><a href="/settings">Settings</a>{{end}}
    <a href="/export.csv" id="exportLink">Export CSV</a>
    <form method="POST" action="/logout" class="inline">
      <input type="hidden" name="csrf" value="{{.CSRF}}">
      <button class="btn ghost" type="submit">Sign out</button>
    </form>
  </nav>
</header>

<div class="toolbar" id="dash-toolbar" data-tz="{{.TZ}}">
  <label>From<input type="date" id="from" value="{{.From}}"></label>
  <label>To<input type="date" id="to" value="{{.To}}"></label>
  {{if .Sets}}
  <label>Survey
    <select id="setSelect">
      {{range .Sets}}<option value="{{.ID}}"{{if eq .ID $.SetID}} selected{{end}}>{{if .Name}}{{.Name}}{{else}}Set #{{.ID}}{{end}}{{if .IsDefault}} (default){{end}}</option>{{end}}
    </select>
  </label>
  {{end}}
  <label class="switch" title="Include responses that were saved but never submitted">
    <input type="checkbox" id="includeIncomplete">
    <span class="switch-track"></span>
    <span class="switch-label">Including incomplete</span>
  </label>
  <button class="btn primary" id="apply" type="button">Apply</button>
  <span id="rangeNote"></span>
</div>

<div class="kpis" id="kpis"></div>

<div class="chart-card full" id="trend-card">
  <h3>Responses over time</h3>
  <div class="cbox"><canvas id="trendChart"></canvas></div>
</div>

<div class="charts" id="charts"></div>

<div class="chart-card" id="comments-card">
  <h3>Recent comments</h3>
  <div id="comments"></div>
</div>
{{end}}
{{define "scripts"}}
<script src="{{asset "/static/vendor/chart.min.js"}}"></script>
<script src="{{asset "/static/js/dashboard.js"}}"></script>
{{end}}
