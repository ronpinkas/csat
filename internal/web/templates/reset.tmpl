{{define "title"}}{{.SiteName}} — Set a new password{{end}}
{{define "content"}}
<section class="card">
  {{if .Invalid}}
    <h1>Reset link not valid</h1>
    <p class="lede">This reset link is invalid, has expired, or has already been used. Ask an admin to send a new one.</p>
    <p><a href="/login{{if .Ref}}?ref={{.Ref}}{{end}}">Back to sign in</a></p>
  {{else}}
    <h1>Set a new password</h1>
    <p class="lede">Choose a new password for your {{.SiteName}} account.</p>
    {{if .Error}}<div class="notice err">{{.Error}}</div>{{end}}
    <form method="POST" action="/reset?t={{.Token}}">
      <input type="hidden" name="csrf" value="{{.FormCSRF}}">
      <input type="hidden" name="t" value="{{.Token}}">
      {{if .Ref}}<input type="hidden" name="ref" value="{{.Ref}}">{{end}}
      <div class="form-row">
        <label for="new">New password</label>
        <input id="new" type="password" name="new" minlength="12" autocomplete="new-password" required>
      </div>
      <div class="form-row">
        <label for="confirm">Confirm password</label>
        <input id="confirm" type="password" name="confirm" minlength="12" autocomplete="new-password" required>
      </div>
      <button class="btn primary" type="submit">Set password</button>
    </form>
  {{end}}
</section>
{{end}}
