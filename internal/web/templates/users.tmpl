{{define "title"}}{{.SiteName}} — Users{{end}}
{{define "content"}}
<header class="admin-head">
  <h1>Users</h1>
  <nav class="admin-nav">
    <a href="/dashboard">Dashboard</a><a href="/settings">Settings</a>
    <form method="POST" action="/logout" class="inline">
      <input type="hidden" name="csrf" value="{{.CSRF}}"><button class="btn ghost">Sign out</button>
    </form>
  </nav>
</header>

{{if .Error}}<div class="notice err">{{.Error}}</div>{{end}}
{{if .InviteLink}}<div class="notice ok">Invite link — copy and send it to the new user (single use, expires):<span class="code">{{.InviteLink}}</span></div>{{end}}

<section class="card">
  <h3>Invite a user</h3>
  <form method="POST" action="/users/invite">
    <input type="hidden" name="csrf" value="{{.CSRF}}">
    <div class="toolbar">
      <label>Username (optional)<input name="username" placeholder="blank = they choose"></label>
      <label>Role
        <select name="role">
          <option value="viewer">Viewer (read-only)</option>
          <option value="admin">Admin</option>
        </select>
      </label>
      <button class="btn primary" type="submit">Create invite</button>
    </div>
  </form>
</section>

<section class="card" style="margin-top:16px">
  <table>
    <thead><tr><th>Username</th><th>Role</th><th>Status</th><th></th></tr></thead>
    <tbody>
    {{range .Users}}
      <tr>
        <td>{{.Username}}</td>
        <td>{{.Role}}</td>
        <td>{{if .Active}}Active{{else}}Inactive{{end}}{{if .MustChangePW}} · pending first login{{end}}</td>
        <td>
          {{if .Active}}
          <form method="POST" action="/users/deactivate" class="inline">
            <input type="hidden" name="csrf" value="{{$.CSRF}}">
            <input type="hidden" name="user_id" value="{{.ID}}">
            <button class="btn ghost" type="submit">Deactivate</button>
          </form>
          {{end}}
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}
