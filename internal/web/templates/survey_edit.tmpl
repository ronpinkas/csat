{{define "title"}}{{.SiteName}} — Survey{{end}}
{{define "content"}}
<header class="admin-head">
  {{if .LogoURL}}<img class="logo" src="{{.LogoURL}}" alt="{{.SiteName}}">{{end}}
  <h1>Survey</h1>
  <nav class="admin-nav">
    <a href="/dashboard">Dashboard</a><a href="/users">Users</a><a href="/settings">Settings</a>
    <form method="POST" action="/logout" class="inline">
      <input type="hidden" name="csrf" value="{{.CSRF}}"><button class="btn ghost">Sign out</button>
    </form>
  </nav>
</header>

{{if .Error}}<div class="notice err">{{.Error}}</div>{{end}}

<section class="card">
  <h3>Question set</h3>
  <p class="muted">Editing publishes a <strong>new</strong> question set (id increases); existing sets stay
  usable and their past responses keep their original questions. New survey links use the latest set
  unless a link names a specific <code>&amp;set=&lt;id&gt;</code>. The dashboard can view any set.</p>
  <form method="POST" action="/survey">
    <input type="hidden" name="csrf" value="{{.CSRF}}">
    <div class="form-row">
      <label for="definition">Definition (JSON) — editing set #{{.SetID}}</label>
      <textarea id="definition" name="definition" rows="22" spellcheck="false"
        style="width:100%;font-family:ui-monospace,monospace;font-size:13px">{{.JSON}}</textarea>
    </div>
    <button class="btn primary" type="submit">Publish as new set</button>
  </form>
</section>

<section class="card" style="margin-top:16px">
  <h3>Published sets</h3>
  <table>
    <thead><tr><th>Set</th><th></th><th></th></tr></thead>
    <tbody>
      {{range .Sets}}
      <tr>
        <td>#{{.ID}}{{if .Latest}} · <strong>latest</strong>{{end}}</td>
        <td><a href="/survey?set={{.ID}}">Open in editor</a></td>
        <td><a href="/dashboard?set={{.ID}}">View results</a></td>
      </tr>
      {{end}}
    </tbody>
  </table>
</section>
{{end}}
