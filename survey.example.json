{
  "version": 1,
  "intro": {
    "en": "Thanks for contacting Acme Support — a few quick questions, about 30 seconds.",
    "es": "Gracias por contactar a Acme Support — unas preguntas rápidas, unos 30 segundos."
  },
  "thanks": {
    "en": "Thank you! Your feedback helps us improve.",
    "es": "¡Gracias! Sus comentarios nos ayudan a mejorar."
  },
  "questions": [
    {
      "key": "csat",
      "type": "stars",
      "max": 5,
      "required": true,
      "label": {
        "en": "Overall, how satisfied were you?",
        "es": "En general, ¿qué tan satisfecho/a quedó?"
      }
    },
    {
      "key": "recommend",
      "type": "nps",
      "required": true,
      "label": {
        "en": "How likely are you to recommend us to a friend?",
        "es": "¿Qué tan probable es que nos recomiende a un amigo?"
      },
      "ends": {
        "low": { "en": "Not at all likely", "es": "Nada probable" },
        "high": { "en": "Extremely likely", "es": "Muy probable" }
      }
    },
    {
      "key": "resolution",
      "type": "choice",
      "required": true,
      "label": {
        "en": "Was your issue resolved?",
        "es": "¿Se resolvió su problema?"
      },
      "options": [
        { "value": "yes", "label": { "en": "Yes", "es": "Sí" } },
        { "value": "partial", "label": { "en": "Partially", "es": "Parcialmente" } },
        { "value": "no", "label": { "en": "No", "es": "No" } }
      ]
    },
    {
      "key": "topics",
      "type": "multichoice",
      "label": {
        "en": "What did we help with? (choose any)",
        "es": "¿En qué le ayudamos? (elija las que apliquen)"
      },
      "options": [
        { "value": "billing", "label": { "en": "Billing", "es": "Facturación" } },
        { "value": "technical", "label": { "en": "Technical", "es": "Técnico" } },
        { "value": "account", "label": { "en": "Account", "es": "Cuenta" } },
        { "value": "sales", "label": { "en": "Sales", "es": "Ventas" } }
      ]
    },
    {
      "key": "ces",
      "type": "scale",
      "min": 1,
      "max": 7,
      "required": true,
      "label": {
        "en": "How easy was it to get your issue handled?",
        "es": "¿Qué tan fácil fue resolver su asunto?"
      },
      "ends": {
        "low": { "en": "Very hard", "es": "Muy difícil" },
        "high": { "en": "Very easy", "es": "Muy fácil" }
      }
    },
    {
      "key": "comment",
      "type": "text",
      "maxlen": 2000,
      "label": {
        "en": "Anything else you'd like to share?",
        "es": "¿Algo más que quiera comentar?"
      },
      "placeholder": { "en": "Optional", "es": "Opcional" }
    }
  ]
}
