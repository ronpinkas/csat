# Secrets for CSAT. The platform bakes a personalized copy of this file (as .env) into
# each customer's download. For manual deploys, copy to .env, fill in, and chmod 600.
# Loaded automatically (and by systemd via EnvironmentFile). Real env vars win over this file.

# Bootstrap admin password — force-changed on first login.
CSAT_ADMIN_INITIAL_PW=change-me

# Token secret shared with the call platform's link-builder. Leave unset to auto-generate a
# unique per-deployment key on first boot (then see the admin Settings page). To pin it
# explicitly: openssl rand -base64 48
# CSAT_CRYPTO_SECRET=
